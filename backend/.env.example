PORT=4000
NODE_ENV=development
MONGODB_URI=
# openssl rand -hex 64 (use different values for access vs refresh; never commit real secrets)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Optional strict CORS: set CORS_STRICT=true and list origins below.
# Default: open CORS (reflects browser Origin) so deployed SPA works without listing URLs.
FRONTEND_URL=
# CORS_ORIGINS=
# CORS_STRICT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
