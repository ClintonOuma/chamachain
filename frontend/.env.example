# Production default is in .env.production (Render). Override on any host at BUILD.
# Origin only, no /api/v1, no trailing slash.
VITE_API_URL=

# Optional dev-only: direct API origin (default uses Vite proxy /api -> localhost:4000)
# VITE_DEV_API_URL=http://localhost:4000

# Optional AI service origin for AI Coach (if deployed separately)
# VITE_AI_SERVICE_URL=https://your-ai-service.example

